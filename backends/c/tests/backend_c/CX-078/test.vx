// @rfc: backends/c/README.md#target--abi
// @desc: C backend lowers non-native integer widths by emitting helper-backed byte-struct types instead of rejecting them.
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && grep -Fq 'typedef struct { unsigned char b[2]; } vx_u13_t;' out.h && grep -Fq 'vx_ai_add' out.c

&^main() -> #u13 {
    (#u13)7 + (#u13)1
}
