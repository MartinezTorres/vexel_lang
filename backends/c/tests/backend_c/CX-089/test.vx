// @rfc: docs/vexel-rfc.md#name-resolution--modules
// @desc: Bundled std::math array lifting lowers to scalar libc math calls and executes correctly for unary/binary same-shape arrays. | C backend executes std::math phase-1 array lifting
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && printf '%s\n' '#include <math.h>' 'double vx_seed0(void) { return 1.0; }' 'double vx_seed1(void) { return 9.0; }' 'double vx_seed2(void) { return 5.0; }' 'double vx_seed3(void) { return 7.0; }' > stub.c && gcc -std=c11 -O2 out.c stub.c -o out -lm && ./out

::std::math;

&!seed0() -> #f64;
&!seed1() -> #f64;
&!seed2() -> #f64;
&!seed3() -> #f64;

&^main() -> #i32 {
  xs:#f64[2] = [seed0(), seed1()];
  ys:#f64[2] = [seed2(), seed3()];

  roots:#f64[2] = std::math::sqrt(xs);
  mods:#f64[2] = std::math::fmod(ys, [2.0, 4.0]);
  flags:#b[2] = std::math::isfinite(roots);

  ((((#i32)roots[0]) + ((#i32)roots[1]) + ((#i32)mods[0]) + ((#i32)mods[1])) + ((#i32)flags[0]) + ((#i32)flags[1])) == 10 ? 0 : 1
}
