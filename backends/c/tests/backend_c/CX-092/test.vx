// @rfc: docs/vexel-rfc.md#operators--precedence
// @desc: Runtime array literal temporaries inside internal non-reentrant functions must not use invalid static aggregate initializers. | C backend compiles non-reentrant array literal temp path
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && printf '%s\n' '#include <stdint.h>' 'int32_t vx_seed(void) { return 5; }' > stub.c && gcc -std=c11 -O2 out.c stub.c -o out && ./out

#Box(v:#i32);

&(lhs)#Box::.+(rhs:#Box) -> #Box {
  #Box(lhs.v + rhs.v)
}

&!seed() -> #i32;

&work() -> #i32 {
  base:#i32 = seed();
  xs:#i32[2] = [1, 2];
  boxes:#Box[2] = [#Box(base), #Box(base + 1)];
  off:#Box = #Box(10);

  xs .+= base;
  boxes .+= off;

  xs[0] + boxes[1].v
}

&^main() -> #i32 {
  work() == 22 ? 0 : 1
}
