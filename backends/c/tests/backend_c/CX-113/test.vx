// @rfc: docs/vexel-rfc.md#declarations
// @desc: Bundled std::print is an ordinary overloaded library surface; arrays recurse through the generic iterable fallback. | std::print uses overload resolution, not a compiler builtin
// @command: {VEXEL} -b c test.vx && printf '%s\n' '#include <stdint.h>' '#include <stdio.h>' 'void vx_putchar(uint8_t c) { putchar((int)c); }' > stub.c && gcc -std=c11 -O2 out.c stub.c -o out -lm && python3 -c "import subprocess, sys; out = subprocess.check_output(['./out']); sys.exit(0 if out == b'sum=42\\n[1, 2, 3]\\n' else 1)"

::std::print;

&^main() -> #i32 {
  answer:#i32 = 42;
  xs:#i32[3] = [1, 2, 3];

  print("sum=");
  print(answer);
  print_newline();
  print(xs);
  print_newline();
  0
}
