// @rfc: docs/vexel-rfc.md#types
// @desc: Native 64-bit fixed-point mul/div/mod and compound forms execute with precise lowering.
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && grep -Fq 'vx_ai_mul(' out.c && grep -Fq 'vx_ai_udivmod(' out.c && printf '%s\n' '#include "out.h"' 'uint64_t vx_ua(void) { return (uint64_t)7 << 32; }' 'uint64_t vx_ub(void) { return (uint64_t)11 << 32; }' > stub.c && gcc -std=c11 -O2 out.c stub.c -o out && ./out

&!ua() -> #u32.32;
&!ub() -> #u32.32;

&^main() -> #i32 {
  u:#u32.32 = ua();
  v:#u32.32 = ub();

  p:#u32.32 = u * v;
  d:#u32.32 = p / v;
  m:#u32.32 = p % v;

  c:#u32.32 = u;
  c *= v;
  c /= v;
  c %= v;

  ok:#b = (d == u) && (c == u) && (m < v);
  ok ? 0 : 1
}
