// @rfc: docs/vexel-rfc.md#types
// @desc: Nested arrays of named structs are valid arrays and compile through the C backend.
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && gcc -std=c11 -O2 out.c -o out -lm && ./out

#Pixel(r:#u8, g:#u8, b:#u8);

&^main() -> #i32 {
  img:#Pixel[2][2] = [
    [#Pixel(1, 2, 3), #Pixel(4, 5, 6)],
    [#Pixel(7, 8, 9), #Pixel(10, 11, 12)]
  ];

  total:#i32 = (#i32)img[0][0].r +
               (#i32)img[0][1].g +
               (#i32)img[1][0].b +
               (#i32)img[1][1].r;

  total == 25 ? 0 : 1
}
