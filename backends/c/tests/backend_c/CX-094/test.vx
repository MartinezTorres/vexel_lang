// @rfc: docs/vexel-rfc.md#types
// @desc: Fixed-point native-width subset (same-type unary -, +/-, comparisons) lowers through raw integer storage in C backend.
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && grep -Fq 'uint16_t vx_add_u(' out.h && grep -Fq 'int16_t vx_sub_s(' out.h && gcc -std=c11 -O2 -c out.c -o out.o

&^add_u(a:#u8.8, b:#u8.8) -> #u8.8 { a + b }
&^sub_s(a:#i10.6, b:#i10.6) -> #i10.6 { a - b }
&^neg_u(a:#u8.8) -> #u8.8 { -a }
&^lt_s(a:#i10.6, b:#i10.6) -> #b { a < b }
&^eq_u(a:#u8.8, b:#u8.8) -> #b { a == b }
&^main() -> #i32 { 0 }
