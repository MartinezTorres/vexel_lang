// @rfc: docs/vexel-rfc.md#types
// @desc: Non-native non-zero-fraction fixed-point unary/add-sub/comparisons and +=/-= lower through extint helpers.
// @expect-exit: 0
// @command: {VEXEL} -b c test.vx && grep -Fq 'vx_ai_add(' out.c && grep -Fq 'vx_ai_sub(' out.c && grep -Fq 'vx_ai_neg(' out.c && (grep -Fq 'vx_ai_scmp(' out.c || grep -Fq 'vx_ai_ucmp(' out.c) && gcc -std=c11 -O2 -c out.c -o out.o

&^arith72(a:#i40.32, b:#i40.32) -> #i40.32 {
  -a + b - a
}

&^cmp72(a:#i40.32, b:#i40.32) -> #b {
  (a + b) >= (a - b)
}

&^acc72(a:#u40.32, b:#u40.32) -> #u40.32 {
  x:#u40.32 = a;
  x += b;
  x -= a;
  x
}

&^main() -> #i32 { 0 }
