::std::math;

&!seed0() -> #f64;
&!seed1() -> #f64;
&!seed2() -> #f64;
&!seed3() -> #f64;

&^main() -> #i32 {
  xs:#f64[2] = [seed0(), seed1()];
  ys:#f64[2] = [seed2(), seed3()];
  m:#f64[2][2] = [[5.0, 7.0], [8.0, 9.0]];
  row:#f64[2] = [2.0, 4.0];

  roots:#f64[2] = std::math::sqrt(xs);
  mods:#f64[2] = std::math::fmod(ys, [2.0, 4.0]);
  powed:#f64[2] = std::math::pow(xs, 2.0);
  mods2:#f64[2][2] = std::math::fmod(m, row);
  flags:#b[2] = std::math::isfinite(roots);

  (((((((((#i32)roots[0]) + ((#i32)roots[1])) + ((#i32)mods[0])) + ((#i32)mods[1])) + ((#i32)powed[0])) + ((#i32)powed[1])) + ((#i32)mods2[1][0])) + ((#i32)mods2[1][1])) + ((#i32)flags[0]) + ((#i32)flags[1]) == 93 ? 0 : 1
}
