// @rfc: docs/vexel-rfc.md#name-resolution--modules
// @desc: Frontend compile-time evaluation folds supported std::math calls from bundled std/ module. | std::math calls fold in constexpr evaluation

::std::math;

&^main() -> #i32 {
  a:#f64 = std::math::sqrt(9.0);
  b:#f64 = std::math::cos(0.0);
  c:#f32 = std::math::sinf((#f32)0.0);
  (#i32)a + (#i32)b + (#i32)c
}
