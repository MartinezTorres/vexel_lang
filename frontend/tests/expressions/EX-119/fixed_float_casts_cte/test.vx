&^main() -> #i32 {
  a:#u8.8 = (#u8.8)1.5;
  b:#f64 = (#f64)a;
  c:#i8.8 = (#i8.8)-1.5;
  d:#f64 = (#f64)c;
  e:#i16.0 = (#i16.0)c;
  f:#f32 = (#f32)((#u8.8)2.25);
  ok:#b =
    (b > 1.49 && b < 1.51) &&
    (d > -1.51 && d < -1.49) &&
    (e == (#i16.0)-1) &&
    (f > 2.24 && f < 2.26);
  ok ? 0 : 1
}
