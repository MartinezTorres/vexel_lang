&!ua() -> #u40.32;
&!sa() -> #i40.32;

&^main() -> #i32 {
  u:#u40.32 = ua();
  s:#i40.32 = sa();

  u16f:#u16.8 = (#u16.8)u;
  u40f:#u40.32 = (#u40.32)u16f;

  i24:#i24 = (#i24)s;
  i40f:#i40.32 = (#i40.32)i24;

  f:#f64 = (#f64)s;
  s2:#i40.32 = (#i40.32)f;

  b:#b = (#b)s2;
  u40:#u40 = (#u40)s2;

  b ? ((#i32)u40) : ((#i32)i40f)
}
