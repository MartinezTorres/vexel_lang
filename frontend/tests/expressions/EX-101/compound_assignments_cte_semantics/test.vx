// @rfc: docs/vexel-rfc.md#expressions--control
// @desc: Compound assignments evaluate correctly at compile time, including logical short-circuit and indexed lhs single evaluation. | CTE folds compound assignment semantics

&^main() -> #i32 {
    a:#i32 = 10;
    a += 2;
    a *= 3;
    a -= 6;
    a /= 3;

    u:#u8 = 5;
    u %= 4;
    u |= 2;
    u &= 3;
    u ^= 1;
    u <<= 1;
    u >>= 2;

    rhs:#u8 = 0;
    x:#b = 0;
    x &&= ((rhs = rhs + 1) == 1);
    y:#b = 1;
    y &&= ((rhs = rhs + 1) == 1);
    z:#b = 1;
    z ||= ((rhs = rhs + 1) == 2);
    w:#b = 0;
    w ||= ((rhs = rhs + 1) == 2);

    idx:#u8 = 0;
    hits:#u8 = 0;
    arr:#b[4] = [0, 0, 0, 0];
    arr[(idx = idx + 1)] ||= ((hits = hits + 1) == 1);
    arr[(idx = idx + 1)] &&= ((hits = hits + 1) == 2);

    a + (#i32)u + (#i32)rhs +
    ((#i32)x) + ((#i32)y) + ((#i32)z) + ((#i32)w) +
    (#i32)idx + (#i32)hits +
    ((#i32)arr[1]) + ((#i32)arr[2])
}
