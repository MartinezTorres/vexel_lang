&!sx() -> #i40.8;
&!sy() -> #i40.8;

&^main() -> #i32 {
  x:#i40.8 = sx();
  y:#i40.8 = sy();
  a:#i40.8 = x & y;
  b:#i40.8 = x | y;
  c:#i40.8 = x ^ y;
  d:#i40.8 = x >> y;
  e:#i40.8 = x << y;
  f:#i40.8 = ~x;

  z:#u40.8 = (#u40.8)x;
  u:#u40.8 = z & z;
  v:#u40.8 = z >> z;

  k:#i40.8 = x;
  k &= y;
  k |= y;
  k ^= y;
  k >>= y;
  k <<= y;

  m:#u40.8 = z;
  m &= z;
  m |= z;
  m ^= z;
  m >>= z;
  m <<= z;

  0
}
