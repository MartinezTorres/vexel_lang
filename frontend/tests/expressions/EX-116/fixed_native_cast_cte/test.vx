&^main() -> #i32 {
  a:#u8.8 = (#u8.8)3;
  b:#u16.0 = (#u16.0)a;
  c:#u10.-2 = (#u10.-2)12;
  d:#u8.0 = (#u8.0)c;
  e:#b = (#b)a;
  f:#b = (#b)((#u8.8)0);
  s0:#i16.0 = -((#i16.0)3);
  s1:#i8.8 = (#i8.8)s0;
  s2:#i16.0 = (#i16.0)s1;
  sref:#i16.0 = -((#i16.0)3);
  (b == (#u16.0)3 && d == (#u8.0)12 && e && !f && s2 == sref) ? 0 : 1
}
