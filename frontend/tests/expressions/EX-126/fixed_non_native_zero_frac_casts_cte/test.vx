&^main() -> #i32 {
  u72:#u72.0 = (#u72.0)300;
  s72:#i72.0 = (#i72.0)-7;

  u80:#u80.0 = (#u80.0)u72;
  s80:#i80.0 = (#i80.0)s72;
  i32v:#i32 = (#i32)s72;
  u16v:#u16 = (#u16)u72;

  b0:#b = (#b)((#u72.0)0);
  b1:#b = (#b)u72;

  f:#f64 = (#f64)((#u72.0)42);
  back:#u72.0 = (#u72.0)f;

  bytes:#u8[9] = (#u8[9])u72;

  ok:#b =
    (u80 == (#u80.0)300) &&
    (s80 == (#i80.0)-7) &&
    (i32v == (#i32)-7) &&
    (u16v == (#u16)300) &&
    (!b0) &&
    b1 &&
    ((#i32)f == 42) &&
    (back == (#u72.0)42) &&
    (bytes[0] == (#u8)0) &&
    (bytes[7] == (#u8)1) &&
    (bytes[8] == (#u8)44);
  ok ? 0 : 1
}
