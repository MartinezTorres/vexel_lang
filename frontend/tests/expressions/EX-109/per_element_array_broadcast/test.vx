// @rfc: docs/vexel-rfc.md#operators--precedence
// @desc: Dotted per-element operators over arrays lower with strict broadcasting (scalar lifting and singleton expansion). | Per-element array operators lower with broadcasting

#Box(v:#i32);

&(lhs)#Box::.+(rhs:#Box) -> #Box {
  Box(lhs.v + rhs.v)
}

&!seed() -> #i32;
&!tick() -> #b;

&^main() -> #i32 {
  base:#i32 = seed();
  bit:#b = tick();

  xs:#i32[2] = [base, base + 1];
  m:#i32[2][2] = [[1, 2], [3, 4]];
  row:#i32[2] = [10, 20];
  boxes:#Box[2] = [Box(base), Box(base + 1)];
  offs:#Box[2] = [Box(10), Box(20)];

  a:#i32[2] = xs .+ 3;
  b:#i32[2][2] = m .* row;
  c:#b[2] = a .== [4, 5];
  d:#b[2] = [base == base + 1, bit] .|| [1 == 1, 0 == 1];
  e:#Box[2] = boxes .+ offs;

  (((((((#i32)b[1][0]) + ((#i32)b[1][1])) + ((#i32)c[0]) + ((#i32)c[1])) + ((#i32)d[0]) + ((#i32)d[1])) + e[1].v) + base)
}
