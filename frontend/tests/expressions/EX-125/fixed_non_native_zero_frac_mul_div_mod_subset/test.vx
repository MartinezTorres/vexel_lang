&^acc72_u(a:#u72.0, b:#u72.0, c:#u72.0) -> #u72.0 {
  x:#u72.0 = a;
  x = x * b;
  x = x / c;
  x = x % b;
  x *= b;
  x /= c;
  x %= b;
  x
}

&^acc72_s(a:#i72.0, b:#i72.0, c:#i72.0) -> #i72.0 {
  x:#i72.0 = a;
  x = x * b;
  x = x / c;
  x = x % b;
  x *= b;
  x /= c;
  x %= b;
  x
}

&^main() -> #i32 { 0 }
