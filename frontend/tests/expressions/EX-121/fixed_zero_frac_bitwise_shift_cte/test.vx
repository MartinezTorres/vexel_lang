&^main() -> #i32 {
  a:#u8.0 = (#u8.0)170;
  b:#u8.0 = (#u8.0)204;

  andv:#u8.0 = a & b;
  orv:#u8.0 = a | b;
  xorv:#u8.0 = a ^ b;
  notv:#u8.0 = ~a;
  lsh:#u8.0 = a << (#u8.0)1;
  rsh:#u8.0 = a >> (#u8.0)1;

  acc:#u8.0 = a;
  acc &= b;
  acc |= (#u8.0)1;
  acc ^= (#u8.0)3;
  acc <<= (#u8.0)1;
  acc >>= (#u8.0)2;

  ok:#b =
    (andv == (#u8.0)136) &&
    (orv == (#u8.0)238) &&
    (xorv == (#u8.0)102) &&
    (notv == (#u8.0)85) &&
    (lsh == (#u8.0)84) &&
    (rsh == (#u8.0)85) &&
    (acc == (#u8.0)5);
  ok ? 0 : 1
}
