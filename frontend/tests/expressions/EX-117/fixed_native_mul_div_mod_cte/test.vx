&^main() -> #i32 {
  a:#u8.8 = (#u8.8)6;
  b:#u8.8 = (#u8.8)2;
  c:#u8.8 = (#u8.8)3;
  mul:#u8.8 = a * b;
  div:#u8.8 = a / c;
  rem:#u8.8 = a % b;
  sm:#i8.8 = -((#i8.8)3);
  sd:#i8.8 = (#i8.8)2;
  q:#i8.8 = sm / sd;
  r:#i8.8 = sm % sd;
  ok:#b =
    ((#u16.0)mul == (#u16.0)12) &&
    ((#u16.0)div == (#u16.0)2) &&
    ((#u16.0)rem == (#u16.0)0) &&
    ((#i16.0)q == (#i16.0)-1) &&
    ((#i16.0)r == (#i16.0)-1);
  ok ? 0 : 1
}
