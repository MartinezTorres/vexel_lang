// @rfc: docs/vexel-rfc.md#types
// @desc: Type names and ordinary function names occupy distinct namespaces after hash constructors were introduced. | A type and a function may share the same surface name

#Point(x:#i32);

&Point(x:#i32) -> #i32 {
  x + 5
}

&^main() -> #i32 {
  #Point(7).x + Point(8)
}
